---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";

export async function getStaticPaths() {
  const providers = await getCollection("providers");
  const countrySlugs = [...new Set(providers.map((p) => p.data.country_slug))];

  return countrySlugs.map((slug) => {
    const countryProviders = providers.filter(
      (p) => p.data.country_slug === slug,
    );
    const countryName = countryProviders[0].data.country;
    return {
      params: { country: slug },
      props: {
        countryName,
        providers: countryProviders.sort((a, b) =>
          a.data.name.localeCompare(b.data.name),
        ),
      },
    };
  });
}

const { country } = Astro.params;
const { countryName, providers } = Astro.props;
---

<BaseLayout
  title={`ERPNext Providers in ${countryName}`}
  description={`${providers.length} ERPNext service providers in ${countryName}. Find implementation partners, consultants, and support services.`}
>
  <nav class="text-sm text-text-muted mb-6">
    <a href={import.meta.env.BASE_URL} class="hover:text-primary">Home</a>
    <span class="mx-1">/</span>
    <span>{countryName}</span>
  </nav>

  <h1 class="text-3xl font-bold text-primary mb-2">
    ERPNext Providers in {countryName}
  </h1>
  <p class="text-text-muted mb-8">
    {providers.length} service {
      providers.length === 1 ? "provider" : "providers"
    }
  </p>

  <div class="grid gap-4 md:grid-cols-2">
    {
      providers.map((p) => (
        <a
          href={`${import.meta.env.BASE_URL}/${country}/${p.id}/`}
          class="block p-5 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all bg-white"
        >
          <div class="flex items-start justify-between gap-2">
            <div>
              <h2 class="font-semibold text-lg">{p.data.name}</h2>
              <p class="text-sm text-text-muted">
                {p.data.city ? `${p.data.city}` : countryName}
                {p.data.year_founded
                  ? ` \u00B7 Est. ${p.data.year_founded}`
                  : ""}
              </p>
            </div>
            {p.data.partner_tier && (
              <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-accent/10 text-accent whitespace-nowrap">
                {p.data.partner_tier} Partner
              </span>
            )}
          </div>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-2 text-xs text-text-muted">
            {p.data.languages.length > 0 && (
              <span>
                <Icon name="message-circle" size={12} />{" "}
                {p.data.languages.join(", ")}
              </span>
            )}
            {p.data.team_size && (
              <span>
                <Icon name="users" size={12} /> {p.data.team_size}
              </span>
            )}
          </div>
          {p.data.industries.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {p.data.industries.map((ind) => (
                <span class="px-2 py-0.5 text-xs rounded bg-surface text-text-muted">
                  {ind}
                </span>
              ))}
            </div>
          )}
          {p.data.also_serves.length > 0 && (
            <p class="text-xs text-text-muted mt-2">
              <Icon name="map" size={12} /> Also serves:{" "}
              {p.data.also_serves.join(", ")}
            </p>
          )}
        </a>
      ))
    }
  </div>
</BaseLayout>
