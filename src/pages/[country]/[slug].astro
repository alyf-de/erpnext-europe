---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";

export async function getStaticPaths() {
  const providers = await getCollection("providers");
  return providers.map((entry) => ({
    params: { country: entry.data.country_slug, slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const {
  name,
  website,
  city,
  country,
  partner_tier,
  industries,
  languages,
  year_founded,
  team_size,
  also_serves,
} = entry.data;

// Extract h2 headings for section navigation
const sections = headings.filter((h) => h.depth === 2);
---

<BaseLayout
  title={`${name} — ERPNext Service Provider`}
  description={`${name} is an ERPNext service provider in ${city ? `${city}, ` : ""}${country}. ${industries.length > 0 ? `Specializing in ${industries.slice(0, 3).join(", ")}.` : ""}`}
>
  <nav class="text-sm text-text-muted mb-6">
    <a href={import.meta.env.BASE_URL} class="hover:text-primary">Home</a>
    <span class="mx-1">/</span>
    <a
      href={`${import.meta.env.BASE_URL}/${entry.data.country_slug}/`}
      class="hover:text-primary">{country}</a
    >
    <span class="mx-1">/</span>
    <span>{name}</span>
  </nav>

  <header class="mb-8 pb-6 border-b border-border">
    <div
      class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4"
    >
      <div>
        <h1 class="text-3xl font-bold text-primary mb-3">{name}</h1>

        <div
          class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-text-muted mb-4"
        >
          {
            city && (
              <span>
                <Icon name="map-pin" /> {city}, {country}
              </span>
            )
          }
          {
            !city && (
              <span>
                <Icon name="map-pin" /> {country}
              </span>
            )
          }
          {
            year_founded && (
              <span>
                <Icon name="calendar" /> Founded {year_founded}
              </span>
            )
          }
          {
            team_size && (
              <span>
                <Icon name="users" /> {team_size}
              </span>
            )
          }
        </div>

        <div class="flex flex-wrap gap-2 mb-4">
          {
            partner_tier && (
              <a
                href={`${import.meta.env.BASE_URL}/partnership/`}
                class="inline-block px-3 py-1 text-sm font-medium rounded-full bg-accent/10 text-accent hover:bg-accent/20 transition-colors"
              >
                {partner_tier} Partner
              </a>
            )
          }
          {
            industries.map((ind) => (
              <span class="inline-block px-3 py-1 text-sm rounded-full bg-surface text-text-muted">
                {ind}
              </span>
            ))
          }
        </div>

        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
          {
            languages.length > 0 && (
              <span class="text-text-muted">
                <Icon name="message-circle" /> {languages.join(", ")}
              </span>
            )
          }
          {
            also_serves.length > 0 && (
              <span class="text-text-muted">
                <Icon name="map" /> Also serves: {also_serves.join(", ")}
              </span>
            )
          }
        </div>
      </div>

      {
        website && (
          <a
            href={website}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white font-medium rounded-lg hover:bg-primary-light transition-colors shrink-0"
          >
            <Icon name="external-link" size={16} /> Visit Website
          </a>
        )
      }
    </div>
  </header>

  {
    sections.length > 1 && (
      <nav class="flex flex-wrap gap-2 mb-8 text-sm">
        {sections.map((s) => (
          <a
            href={`#${s.slug}`}
            class="px-3 py-1.5 rounded-md bg-surface text-text-muted hover:text-primary hover:bg-surface-dark transition-colors"
          >
            {s.text}
          </a>
        ))}
      </nav>
    )
  }

  <article
    class="prose prose-neutral max-w-none
    [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:text-primary [&>h2]:mt-10 [&>h2]:mb-4 [&>h2]:border-b [&>h2]:border-border [&>h2]:pb-2
    [&>h3]:text-base [&>h3]:font-semibold [&>h3]:text-text-muted [&>h3]:mt-5 [&>h3]:mb-1
    [&>p]:my-2 [&>p]:leading-relaxed
    [&>ul]:my-2 [&>ul]:pl-6
    [&>hr]:hidden [&>hr~*]:hidden
    [&_a]:text-primary [&_a:hover]:underline"
  >
    <Content />
  </article>
</BaseLayout>
